generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed via bcryptjs – null for OAuth users
  /// "user" | "admin" — admins can access /admin (also see ADMIN_EMAILS env)
  role          String    @default("user")
  tier          String    @default("free")
  /// B2C Stripe customer (Checkout / Customer Portal)
  stripeCustomerId         String? @unique
  stripeSubscriptionId     String? @unique
  stripeSubscriptionStatus String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  pushSubscriptions PushSubscription[]
  organizationMember OrganizationMember?
  driverPresence DriverPresence?
  crowdPosts       CrowdPost[]
  rewardLedger     RewardLedgerEntry[]
  vehicleInspections VehicleInspection[]

  @@map("users")
}

/// Key/value platform config (e.g. Stripe overrides). Secrets stored here apply at runtime after cache TTL (see lib/platformSettings).
model PlatformSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── App models ────────────────────────────────────────────────────

model PushSubscription {
  id                 String   @id @default(cuid())
  endpoint           String   @unique
  p256dh             String
  auth               String
  deviceId           String?
  userId             String?
  lastLat            Float?
  lastLng            Float?
  radiusKm           Float    @default(2)
  incidentTypeFilter String?
  severityMin        Int?
  quietHoursStart    String?
  quietHoursEnd      String?
  cityId             String?
  tier               String   @default("free")
  minTowScore        Int?
  /// Comma-separated list of incident sources the user prefers: e.g. "tomtom", "511on", or "tomtom,511on"
  incidentSources    String?
  /// Up to 3 driver-defined quick navigation destinations: [{ id, label, lat, lng }, ...]
  driverQuickNavs    Json?
  /// Driver map UI: incident type chips, list radius (km), traffic layer — see lib/driverMapFilters.ts
  driverMapFilters   Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("push_subscriptions")
}

model NotificationLog {
  id               String   @id @default(cuid())
  subscriptionId   String
  incidentId       String
  createdAt        DateTime @default(now())

  @@unique([subscriptionId, incidentId])
  @@map("notification_logs")
}

model IncidentSnapshot {
  id             String    @id @default(cuid())
  externalId     String
  lat            Float
  lng            Float
  city           String
  iconCategory   Int
  magnitudeOfDelay Int?
  description    String?
  from_          String?   @map("from_")
  to_            String?   @map("to_")
  startTime      DateTime?
  endTime        DateTime?
  fetchedAt      DateTime  @default(now())

  @@index([city, fetchedAt])
  @@index([externalId, fetchedAt])
  @@map("incident_snapshots")
}

model TrafficCamera {
  id          String   @id @default(cuid())
  externalId  String   @unique
  lat         Float
  lng         Float
  name        String
  roadName    String?
  intersection String?
  imageUrl    String
  city        String   @default("DitchApp")
  updatedAt   DateTime @updatedAt

  @@index([city])
  @@index([lat, lng])
  @@map("traffic_cameras")
}

// ─── Billing / organizations (B2B seats) ─────────────────────────────

model Organization {
  id               String    @id @default(cuid())
  name             String
  stripeCustomerId String?   @unique
  billingEmail     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members      OrganizationMember[]
  subscription OrganizationSubscription?
  serviceArea    OrganizationServiceArea?
  fleetVehicles           FleetVehicle[]
  inspectionTemplates     InspectionTemplate[]
  vehicleInspections      VehicleInspection[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @unique
  role           String   @default("driver") // "admin" | "driver"
  seatActive     Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organization_members")
}

model OrganizationSubscription {
  id                   String    @id @default(cuid())
  organizationId       String    @unique
  stripeSubscriptionId String    @unique
  status               String    @default("incomplete")
  seatQuantity         Int       @default(1)
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_subscriptions")
}

// ─── Social / fleet presence (polling-based “realtime” MVP) ───────────

model DriverPresence {
  userId    String   @id
  lat       Float
  lng       Float
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_presence")
}

model CrowdPost {
  id              String   @id @default(cuid())
  userId          String
  body            String   @db.VarChar(4000)
  moderationState String @default("visible")
  suspiciousScore Float    @default(0)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("crowd_posts")
}

model RewardLedgerEntry {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("reward_ledger_entries")
}

model OrganizationServiceArea {
  id             String   @id @default(cuid())
  organizationId String   @unique
  geoJson        Json
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_service_areas")
}

// ─── DVIR / vehicle inspections ─────────────────────────────────────

model InspectionTemplate {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions     InspectionTemplateVersion[]

  @@index([organizationId])
  @@map("inspection_templates")
}

model InspectionTemplateVersion {
  id              String   @id @default(cuid())
  templateId      String
  version         Int
  /// Sections/items JSON — see lib/inspection/checklistSchema.ts
  checklistSchema Json
  createdAt       DateTime @default(now())

  template                InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  vehicleInspections      VehicleInspection[]
  fleetVehiclesAsDefault  FleetVehicle[]       @relation("FleetVehicleDefaultTemplate")

  @@unique([templateId, version])
  @@index([templateId])
  @@map("inspection_template_versions")
}

model FleetVehicle {
  id                                  String    @id @default(cuid())
  organizationId                      String
  unitNumber                          String
  /// truck | trailer | bus | other
  vehicleType                         String    @default("truck")
  plate                               String?
  vin                                 String?
  notes                               String?
  active                              Boolean   @default(true)
  metadata                            Json?
  defaultInspectionTemplateVersionId  String?
  createdAt                           DateTime  @default(now())
  updatedAt                           DateTime  @updatedAt

  organization               Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultInspectionTemplateVersion InspectionTemplateVersion? @relation("FleetVehicleDefaultTemplate", fields: [defaultInspectionTemplateVersionId], references: [id], onDelete: SetNull)
  inspections                VehicleInspection[]

  @@unique([organizationId, unitNumber])
  @@index([organizationId])
  @@map("fleet_vehicles")
}

model VehicleInspection {
  id                String    @id @default(cuid())
  organizationId    String
  fleetVehicleId    String
  driverUserId      String
  /// PRE_TRIP | POST_TRIP
  kind              String
  templateVersionId String
  /// draft | finalized
  status            String    @default("draft")
  startedAt         DateTime  @default(now())
  finalizedAt       DateTime?
  odometerKm        Float?
  lat               Float?
  lng               Float?
  locationLabel     String?
  /// ok | defects | out_of_service — set when finalized
  overallSeverity   String?

  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fleetVehicle    FleetVehicle              @relation(fields: [fleetVehicleId], references: [id], onDelete: Cascade)
  driver          User                      @relation(fields: [driverUserId], references: [id], onDelete: Cascade)
  templateVersion InspectionTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  items           VehicleInspectionItem[]
  attachments     InspectionAttachment[]

  @@index([organizationId, finalizedAt])
  @@index([fleetVehicleId, finalizedAt])
  @@index([driverUserId, finalizedAt])
  @@map("vehicle_inspections")
}

model VehicleInspectionItem {
  id           String  @id @default(cuid())
  inspectionId String
  /// Stable id from checklist item definition (e.g. sec0-it2)
  itemKey      String
  sectionIndex Int
  itemIndex    Int
  /// ok | defect | na
  result       String
  /// minor | major | out_of_service
  severity     String?
  defectLabel  String?
  notes        String?

  inspection  VehicleInspection       @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  attachments InspectionAttachment[]

  @@index([inspectionId])
  @@map("vehicle_inspection_items")
}

model InspectionAttachment {
  id           String   @id @default(cuid())
  inspectionId String
  itemId       String?
  /// photo | signature
  kind         String
  storageKey   String
  publicUrl    String?
  contentType  String
  createdAt    DateTime @default(now())

  inspection VehicleInspection        @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  item       VehicleInspectionItem?   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@map("inspection_attachments")
}
