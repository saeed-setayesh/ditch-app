generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed via bcryptjs – null for OAuth users
  tier          String    @default("free")
  /// B2C Stripe customer (Checkout / Customer Portal)
  stripeCustomerId         String? @unique
  stripeSubscriptionId     String? @unique
  stripeSubscriptionStatus String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  pushSubscriptions PushSubscription[]
  organizationMember OrganizationMember?
  driverPresence DriverPresence?
  crowdPosts       CrowdPost[]
  rewardLedger     RewardLedgerEntry[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── App models ────────────────────────────────────────────────────

model PushSubscription {
  id                 String   @id @default(cuid())
  endpoint           String   @unique
  p256dh             String
  auth               String
  deviceId           String?
  userId             String?
  lastLat            Float?
  lastLng            Float?
  radiusKm           Float    @default(2)
  incidentTypeFilter String?
  severityMin        Int?
  quietHoursStart    String?
  quietHoursEnd      String?
  cityId             String?
  tier               String   @default("free")
  minTowScore        Int?
  /// Comma-separated list of incident sources the user prefers: e.g. "tomtom", "511on", or "tomtom,511on"
  incidentSources    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("push_subscriptions")
}

model NotificationLog {
  id               String   @id @default(cuid())
  subscriptionId   String
  incidentId       String
  createdAt        DateTime @default(now())

  @@unique([subscriptionId, incidentId])
  @@map("notification_logs")
}

model IncidentSnapshot {
  id             String    @id @default(cuid())
  externalId     String
  lat            Float
  lng            Float
  city           String
  iconCategory   Int
  magnitudeOfDelay Int?
  description    String?
  from_          String?   @map("from_")
  to_            String?   @map("to_")
  startTime      DateTime?
  endTime        DateTime?
  fetchedAt      DateTime  @default(now())

  @@index([city, fetchedAt])
  @@index([externalId, fetchedAt])
  @@map("incident_snapshots")
}

model TrafficCamera {
  id          String   @id @default(cuid())
  externalId  String   @unique
  lat         Float
  lng         Float
  name        String
  roadName    String?
  intersection String?
  imageUrl    String
  city        String   @default("DitchApp")
  updatedAt   DateTime @updatedAt

  @@index([city])
  @@index([lat, lng])
  @@map("traffic_cameras")
}

// ─── Billing / organizations (B2B seats) ─────────────────────────────

model Organization {
  id               String    @id @default(cuid())
  name             String
  stripeCustomerId String?   @unique
  billingEmail     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members      OrganizationMember[]
  subscription OrganizationSubscription?
  serviceArea    OrganizationServiceArea?

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @unique
  role           String   @default("driver") // "admin" | "driver"
  seatActive     Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organization_members")
}

model OrganizationSubscription {
  id                   String    @id @default(cuid())
  organizationId       String    @unique
  stripeSubscriptionId String    @unique
  status               String    @default("incomplete")
  seatQuantity         Int       @default(1)
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_subscriptions")
}

// ─── Social / fleet presence (polling-based “realtime” MVP) ───────────

model DriverPresence {
  userId    String   @id
  lat       Float
  lng       Float
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_presence")
}

model CrowdPost {
  id              String   @id @default(cuid())
  userId          String
  body            String   @db.VarChar(4000)
  moderationState String @default("visible")
  suspiciousScore Float    @default(0)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("crowd_posts")
}

model RewardLedgerEntry {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("reward_ledger_entries")
}

model OrganizationServiceArea {
  id             String   @id @default(cuid())
  organizationId String   @unique
  geoJson        Json
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_service_areas")
}
