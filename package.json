{
  "name": "traficapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "if [ -f prisma/schema.prisma ]; then prisma migrate deploy && prisma generate && next build; else next build; fi",
    "start": "next start",
    "lint": "eslint",
    "brand-icons": "node scripts/regen-brand-icons.mjs",
    "grant-pro": "node scripts/grant-pro.mjs",
    "create-random-admin": "node scripts/create-random-admin.mjs",
    "seed-company": "node scripts/seed-company-account.mjs",
    "db:seed": "prisma db seed",
    "postinstall": "if [ -f prisma/schema.prisma ]; then prisma generate; else echo \"prisma schema not found, skipping prisma generate\"; fi"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.9.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tomtom-international/web-sdk-maps": "^6.25.0",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^17.7.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "prisma": "^6.9.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
